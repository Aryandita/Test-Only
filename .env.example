# ===================================================================
#  DISCORD BOT ENVIRONMENT VARIABLES - COMPLETE CONFIGURATION
# ===================================================================
# 
# Instructions:
# 1. Copy this file and name it .env
# 2. Fill in all REQUIRED variables marked with [REQUIRED]
# 3. Configure OPTIONAL variables as needed
# 4. Never commit .env to version control
#
# For Help:
# - Discord Developer Portal: https://discord.com/developers/applications
# - MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# - Google Gemini API: https://ai.google.dev/
# ===================================================================

# ========================
# REQUIRED DISCORD CONFIG
# ========================
# [REQUIRED] Bot token - Get from Discord Developer Portal
# Path: Settings → Bot → TOKEN
DISCORD_TOKEN=

# [REQUIRED] Client/Application ID - Get from Discord Developer Portal  
# Path: Settings → General Information → Application ID
DISCORD_CLIENT_ID=

# [OPTIONAL] Guild ID - Used for testing slash commands in specific server
# Leave empty to register globally (slower)
# Path: Right-click server → Copy Server ID
DISCORD_GUILD_ID=

# [REQUIRED] Your Discord User ID - Bot owner ID for admin commands
# How to get: Enable Developer Mode → Right-click yourself → Copy User ID
BOT_OWNER_ID=

# ========================
# OPTIONAL BOT SETTINGS
# ========================
# [OPTIONAL] Command prefix - Default: !
BOT_PREFIX=!

# [OPTIONAL] Bot Status - online, idle, dnd, invisible - Default: online
BOT_STATUS=online

# [OPTIONAL] Bot Activity Type - playing, streaming, listening, watching - Default: playing
BOT_ACTIVITY_TYPE=playing

# [OPTIONAL] Bot Activity Text shown under bot name
BOT_ACTIVITY_TEXT=!help | Music & Mini Games

# [OPTIONAL] Bot Language - id (Indonesian) or en (English) - Default: id
BOT_LANGUAGE=id

# ========================
# EMBED COLOR CONFIGURATION
# ========================
# [OPTIONAL] AI Response embed color (HEX format) - Default: #5865F2 (Discord Blurple)
# Format: #RRGGBB (6 hex characters)
# Examples: #FF0000 (red), #00FF00 (green), #0000FF (blue)
AI_EMBED_COLOR_HEX=#5865F2

# [OPTIONAL] General embed color (fallback if AI_EMBED_COLOR_HEX not set)
EMBED_HEX=#5865F2

# ========================
# MUSIC CONTROL EMOJIS
# ========================
# Format: Use unicode emoji (⏭️) or custom Discord emoji (<:name:id:>)
# Get custom emoji ID: Enable Dev Mode → Right-click emoji → Copy Custom Emoji Link
# Example: <:skip:1234567890123456789>

# Skip/Next button emoji
EMOJI_SKIP=⏭️

# Loop mode button emoji
EMOJI_LOOP=🔁

# Autoplay button emoji
EMOJI_AUTOPLAY=♾️

# Stop/quit button emoji
EMOJI_STOP=⏹️

# Lyrics view button emoji
EMOJI_LYRICS=📝

# Now playing indicator emoji  
EMOJI_PLAYING=▶️

# Paused indicator emoji
EMOJI_PAUSED=⏸️

# Queue/playlist emoji
EMOJI_QUEUE=📋

# Volume control emoji
EMOJI_VOLUME=🔊

# Success message emoji
EMOJI_SUCCESS=✅

# Error message emoji
EMOJI_ERROR=❌

# ========================
# REQUIRED DATABASE CONFIG
# ========================
# [REQUIRED] MongoDB Connection URI
# 
# For MongoDB Atlas (Cloud - RECOMMENDED):
#   URI: mongodb+srv://username:password@cluster-name.mongodb.net/database-name?retryWrites=true&w=majority
#   
#   Setup Steps:
#   1. Sign up at https://www.mongodb.com/cloud/atlas
#   2. Create a cluster
#   3. Create database user: Database Access → Add New User
#   4. Add IP whitelist: Network Access → Add IP → Allow Access from Anywhere
#   5. Get connection string: Cluster → Connect → Connect your application
#   6. Replace <username> <password> <cluster> <database-name>
#
# For Local MongoDB:
#   URI: mongodb://localhost:27017/database-name
#   Note: Requires MongoDB server running locally: mongod
#
# Examples:
#   mongodb+srv://botuser:SecurePass123@discord-bot.abcde.mongodb.net/bot-db?retryWrites=true&w=majority
#   mongodb://localhost:27017/discord-bot
#
MONGODB_URI=

# ========================
# LAVALINK MUSIC CONFIG
# ========================
# [REQUIRED] Lavalink server hostname/IP
# Default (local): 127.0.0.1
# Examples:
#   127.0.0.1 (localhost)
#   lavalink.example.com (remote server)
#   node1.music.example.com (cloud hosted)
#
LAVALINK_HOST=127.0.0.1

# [REQUIRED] Lavalink server port
# Default: 2333
# Must match Lavalink server configuration
#
LAVALINK_PORT=2333

# [REQUIRED] Lavalink server password
# Default: youshallnotpass
# Must match Lavalink server configuration (important for security!)
#
LAVALINK_PASSWORD=youshallnotpass

# [OPTIONAL] Use HTTPS/SSL for Lavalink connection
# Default: false
# Set to true if Lavalink server uses HTTPS
#
LAVALINK_SECURE=false

# ========================
# REQUIRED AI/API CONFIG
# ========================
# [REQUIRED] Google Gemini API Key
# Get from: https://ai.google.dev/
#
# Setup Steps:
# 1. Go to https://ai.google.dev/
# 2. Click "Get API Key" → "Create API key in new project"
# 3. Copy the generated API key
# 4. Paste below
#
# IMPORTANT: Keep this secret! Never share this key!
#
GEMINI_API_KEY=

# ===================================================================
# SUPPORT FOR DIFFERENT HOSTING PLATFORMS
# ===================================================================
#
# REPLIT:
#   - Use Secrets instead of .env file
#   - Click "Secrets" (lock icon) in left sidebar
#   - Add environment variables there
#   - They're automatically loaded as process.env
#
# HEROKU / RAILWAY / RENDER:
#   - Add variables in dashboard: Settings → Config Vars
#   - Format: KEY=value (one per line)
#   - No .env file needed
#
# GITHUB CODESPACES:
#   - Create .env file in project root
#   - Use this template
#   - Variables loaded automatically
#
# DOCKER / CONTAINER:
#   - Set env from docker-compose.yml or docker run -e
#   - Or mount .env file into container
#
# VPS / DEDICATED SERVER:
#   - Create .env in project root directory
#   - SSH into server, run: nano .env
#   - Fill in variables, save
#   - Run: node src/index.js
#
# ===================================================================
# VALIDATION CHECKLIST
# ===================================================================
#
# Before starting bot, ensure you have:
#
# DISCORD:
#   [ ] DISCORD_TOKEN - from Developer Portal
#   [ ] DISCORD_CLIENT_ID - from Developer Portal
#   [ ] BOT_OWNER_ID - your Discord user ID
#
# DATABASE:
#   [ ] MONGODB_URI - valid MongoDB connection string
#   [ ] MongoDB account ready (Atlas or local server)
#
# MUSIC:
#   [ ] LAVALINK_HOST - accessible Lavalink server
#   [ ] LAVALINK_PORT - correct port number
#   [ ] LAVALINK_PASSWORD - correct password
#   [ ] Lavalink server is running and accessible
#
# AI:
#   [ ] GEMINI_API_KEY - valid Google Gemini API key
#   [ ] API key has quota available
#
# ===================================================================
# TROUBLESHOOTING
# ===================================================================
#
# Q: Bot won't start - "Cannot find module 'dotenv'"
# A: Make sure to run 'npm install' first in the project root
#
# Q: "Missing required environment variables"
# A: Check all [REQUIRED] variables above are filled in .env
#
# Q: Bot connects but music doesn't work
# A: Verify Lavalink server is running: check LAVALINK_HOST:LAVALINK_PORT
#
# Q: MongoDB connection fails
# A: Check MONGODB_URI format, IP whitelist, network connection
#
# Q: AI responses not working
# A: Verify GEMINI_API_KEY is valid and correct at https://ai.google.dev/
#
# ===================================================================


